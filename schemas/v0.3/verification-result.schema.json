{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RZSchool/aigc-proof/raw/main/schemas/v0.3/verification-result.schema.json",
  "title": "AIGC-Proof Verification Result v0.3",
  "type": "object",
  "required": ["spec_version", "proof_id", "verified_at", "status", "assurance", "checks", "errors", "warnings"],
  "properties": {
    "spec_version": { "const": "0.3.0" },
    "proof_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^urn:uuid:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" }
      ]
    },
    "verified_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "status": { "enum": ["valid", "invalid", "error"] },
    "assurance": {
      "type": "object",
      "required": ["internal_integrity", "creator_identity", "digital_signature", "trusted_time", "originality"],
      "properties": {
        "internal_integrity": { "enum": ["valid", "invalid", "not_evaluated"] },
        "creator_identity": { "enum": ["not_verified", "self_asserted"] },
        "digital_signature": {
          "enum": ["absent", "unsupported", "malformed", "invalid", "valid_untrusted", "valid_locally_trusted", "disabled"]
        },
        "trusted_time": { "const": "not_present" },
        "originality": { "const": "not_evaluated" }
      },
      "additionalProperties": false
    },
    "creator_signature": {
      "type": "object",
      "required": ["display_label", "key_fingerprint", "profile", "local_trust"],
      "properties": {
        "display_label": { "type": "string", "minLength": 1, "maxLength": 200 },
        "key_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "profile": { "type": "string", "minLength": 1 },
        "local_trust": { "enum": ["untrusted", "trusted", "disabled"] }
      },
      "additionalProperties": false
    },
    "checks": { "type": "array", "items": { "$ref": "#/$defs/check" } },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/warning" } }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["code", "status", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "status": { "enum": ["pass", "fail", "skipped"] },
        "path": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "path": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "warning": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "valid" } }, "required": ["status"] },
      "then": {
        "properties": {
          "assurance": {
            "properties": {
              "internal_integrity": { "const": "valid" },
              "creator_identity": { "const": "self_asserted" },
              "digital_signature": { "enum": ["valid_untrusted", "valid_locally_trusted", "disabled"] }
            }
          },
          "errors": { "maxItems": 0 }
        },
        "required": ["creator_signature"]
      }
    },
    {
      "if": { "properties": { "status": { "const": "invalid" } }, "required": ["status"] },
      "then": { "properties": { "errors": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
      "then": {
        "properties": {
          "assurance": { "properties": { "internal_integrity": { "const": "not_evaluated" } } },
          "errors": { "minItems": 1 }
        }
      }
    }
  ],
  "additionalProperties": false
}
