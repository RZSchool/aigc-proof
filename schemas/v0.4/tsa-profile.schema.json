{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RZSchool/aigc-proof/raw/main/schemas/v0.4/tsa-profile.schema.json",
  "title": "AIGC-Proof TSA trust profile v1",
  "type": "object",
  "required": ["profile", "source_label", "endpoint", "endpoint_scope", "allowed_policy_oids", "roots_der_base64", "intermediates_der_base64", "https_roots_der_base64", "revocation", "effective_at", "expires_at"],
  "properties": {
    "profile": { "const": "aigc-proof.tsa-trust-profile.v1" },
    "source_label": { "type": "string", "minLength": 1, "maxLength": 200 },
    "endpoint": { "type": "string", "minLength": 9, "maxLength": 2048, "pattern": "^https://" },
    "endpoint_scope": { "enum": ["public_https", "loopback_test"] },
    "allowed_policy_oids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/oid" }
    },
    "roots_der_base64": { "$ref": "#/$defs/certificates" },
    "intermediates_der_base64": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/base64" }
    },
    "https_roots_der_base64": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/base64" }
    },
    "revocation": {
      "type": "object",
      "required": ["crls_der_base64", "ocsp_responses_der_base64", "required"],
      "properties": {
        "crls_der_base64": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/base64" } },
        "ocsp_responses_der_base64": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/base64" } },
        "required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "effective_at": { "$ref": "#/$defs/canonicalTimestamp" },
    "expires_at": { "$ref": "#/$defs/canonicalTimestamp" }
  },
  "$defs": {
    "oid": { "type": "string", "pattern": "^[0-2](?:\\.(?:0|[1-9][0-9]*)){2,}$" },
    "base64": { "type": "string", "minLength": 4, "maxLength": 1398104, "pattern": "^[A-Za-z0-9+/]+={0,2}$" },
    "certificates": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "$ref": "#/$defs/base64" } },
    "canonicalTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  },
  "additionalProperties": false
}
