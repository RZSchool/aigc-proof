{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RZSchool/aigc-proof/raw/main/schemas/v0.2/verification-result.schema.json",
  "title": "AIGC-Proof Verification Result v0.2",
  "type": "object",
  "required": [
    "spec_version",
    "proof_id",
    "verified_at",
    "status",
    "assurance",
    "checks",
    "errors",
    "warnings"
  ],
  "properties": {
    "spec_version": { "const": "0.2.0" },
    "proof_id": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "pattern": "^urn:uuid:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        }
      ]
    },
    "verified_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "status": { "enum": ["valid", "invalid", "error"] },
    "assurance": {
      "type": "object",
      "required": [
        "internal_integrity",
        "creator_identity",
        "digital_signature",
        "trusted_time",
        "originality"
      ],
      "properties": {
        "internal_integrity": { "enum": ["valid", "invalid", "not_evaluated"] },
        "creator_identity": { "const": "not_verified" },
        "digital_signature": { "const": "not_present" },
        "trusted_time": { "const": "not_present" },
        "originality": { "const": "not_evaluated" }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["code", "status", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "status": { "enum": ["pass", "fail", "skipped"] },
        "path": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "path": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "warning": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
