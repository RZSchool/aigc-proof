{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/aigc-proof/schemas/v0.1/verification-result.schema.json",
  "title": "AIGC-Proof Verification Result v0.1 (Draft)",
  "description": "Minimal, unstable verification result shape for the scaffold stage.",
  "type": "object",
  "required": ["spec_version", "proof_id", "verified_at", "status", "checks"],
  "properties": {
    "spec_version": { "type": "string" },
    "proof_id": { "type": "string" },
    "verified_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string" },
    "checks": { "type": "array" }
  },
  "additionalProperties": false
}
